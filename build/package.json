{
  "name": "ellis-web-bell-build",
  "private": true,
  "description": "Build tooling for the compiled Tailwind stylesheet. See README-BUILD.md.",
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -c tailwind.config.js -i tailwind.input.css -o ../tailwind.css --minify && node verify-css.mjs",
    "watch:css": "tailwindcss -c tailwind.config.js -i tailwind.input.css -o ../tailwind.css --watch",
    "lint": "cd .. && eslint -c build/eslint.config.mjs src/js bell-engine.js",
    "test": "node --test ../tests/bell-engine.test.mjs ../tests/schedule-utils.test.mjs",
    "check:css": "node verify-css.mjs",
    "check:esm": "node verify-esm.mjs"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19",
    "eslint": "^9",
    "globals": "^15"
  }
}